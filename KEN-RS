!
version 15.7
service timestamps debug datetime msec
service timestamps log datetime msec
no service password-encryption
!
hostname KEN-RS
!
boot-start-marker
boot-end-marker
!
!
!
no aaa new-model
!
!
!
mmi polling-interval 60
no mmi auto-configure
no mmi pvc
mmi snmp-timeout 180
!
!
!
!
!
!
!
!
!
!
!
!
!
!
!


!
ip dhcp excluded-address 192.168.1.1
ip dhcp excluded-address 192.168.10.1
ip dhcp excluded-address 192.168.20.1
ip dhcp excluded-address 192.168.30.1
ip dhcp excluded-address 192.168.40.1
ip dhcp excluded-address 192.168.50.1
ip dhcp excluded-address 192.168.1.2
ip dhcp excluded-address 192.168.10.2
ip dhcp excluded-address 192.168.20.2
ip dhcp excluded-address 192.168.30.2
ip dhcp excluded-address 192.168.40.2
ip dhcp excluded-address 192.168.50.2
ip dhcp excluded-address 192.168.1.3
ip dhcp excluded-address 192.168.10.3
ip dhcp excluded-address 192.168.20.3
ip dhcp excluded-address 192.168.30.3
ip dhcp excluded-address 192.168.40.3
ip dhcp excluded-address 192.168.50.3
!
ip dhcp pool VLAN1
 network 192.168.1.0 255.255.255.0
 default-router 192.168.1.3 
!
ip dhcp pool VLAN10-Management
 network 192.168.10.0 255.255.255.0
 default-router 192.168.10.3 
!
ip dhcp pool VLAN20-Voice
 network 192.168.20.0 255.255.255.0
 default-router 192.168.20.3 
!
ip dhcp pool VLAN40-Wifi-Internal
 network 192.168.40.0 255.255.255.0
 default-router 192.168.40.3 
!
ip dhcp pool VLAN30-DATA
 network 192.168.30.0 255.255.255.0
 default-router 192.168.30.3 
!
ip dhcp pool VLAN50-Wifi-Guest
 network 192.168.50.0 255.255.255.0
 default-router 192.168.50.3 
!
!
!
ip cef
no ipv6 cef
!
multilink bundle-name authenticated
!
!
!
!
!
!
!
!
!
!
redundancy
!
!
! 
!
!
!
!
crypto isakmp policy 1
 encr aes
 hash md5
 authentication pre-share
crypto isakmp key Benk@1234 address 0.0.0.0        
!
!
crypto ipsec transform-set TS_AES_SHA esp-aes esp-sha-hmac 
 mode transport
!
crypto ipsec profile HUB-to-SPOKE
 set transform-set TS_AES_SHA 
!
!
!
!
!
!
!
interface Tunnel1
 no shutdown
 description To-SPOKE
 ip address 192.168.210.1 255.255.255.0
 no ip redirects
 ip nhrp authentication DMVPN
 ip nhrp network-id 100
 ip nhrp redirect
 ip ospf network point-to-multipoint
 tunnel source Ethernet0/1
 tunnel mode gre multipoint
 tunnel key 2
 tunnel protection ipsec profile HUB-to-SPOKE
!
interface Ethernet0/0
 no shutdown
 description KEN-CSW002
 ip address 192.168.1.2 255.255.255.0
 duplex auto
 vrrp 1 ip 192.168.1.3
!
interface Ethernet0/0.10
 no shutdown
 encapsulation dot1Q 10
 ip address 192.168.10.2 255.255.255.0
 vrrp 10 ip 192.168.10.3
!
interface Ethernet0/0.20
 no shutdown
 encapsulation dot1Q 20
 ip address 192.168.20.2 255.255.255.0
 vrrp 20 ip 192.168.20.3
!
interface Ethernet0/0.30
 no shutdown
 encapsulation dot1Q 30
 ip address 192.168.30.2 255.255.255.0
 vrrp 30 ip 192.168.30.3
!
interface Ethernet0/0.40
 no shutdown
 encapsulation dot1Q 40
 ip address 192.168.40.2 255.255.255.0
 vrrp 40 ip 192.168.40.3
!
interface Ethernet0/0.50
 no shutdown
 encapsulation dot1Q 50
 ip address 192.168.50.2 255.255.255.0
 vrrp 50 ip 192.168.50.3
!
interface Ethernet0/1
 no shutdown
 ip address 20.0.0.1 255.255.255.252
 duplex auto
!
interface Ethernet0/2
 no shutdown
 no ip address
 shutdown
 duplex auto
!
interface Ethernet0/3
 no shutdown
 no ip address
 shutdown
 duplex auto
!
router ospf 1
 router-id 2.2.2.2
 passive-interface Ethernet0/0
 passive-interface Ethernet0/0.10
 passive-interface Ethernet0/0.20
 passive-interface Ethernet0/0.30
 passive-interface Ethernet0/0.40
 passive-interface Ethernet0/0.50
 network 192.168.1.0 0.0.0.255 area 0
 network 192.168.10.0 0.0.0.255 area 0
 network 192.168.20.0 0.0.0.255 area 0
 network 192.168.30.0 0.0.0.255 area 0
 network 192.168.40.0 0.0.0.255 area 0
 network 192.168.50.0 0.0.0.255 area 0
 network 192.168.210.0 0.0.0.255 area 0
!
ip forward-protocol nd
!
!
no ip http server
no ip http secure-server
ip route 0.0.0.0 0.0.0.0 20.0.0.2
ip route 40.0.0.0 255.255.255.0 20.0.0.2
ip route 60.0.0.0 255.255.255.0 20.0.0.2
!
ipv6 ioam timestamp
!
!
access-list 100 permit ip 192.168.0.0 0.0.255.255 any
!
control-plane
!
!
!
!
!
!
!
!
line con 0
 logging synchronous
line aux 0
line vty 0 4
 login
 transport input none
!
!
end
